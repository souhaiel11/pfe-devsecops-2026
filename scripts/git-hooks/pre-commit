#!/usr/bin/env bash
# Pre-commit hook — Scan des secrets avant commit
# Installation: cp scripts/git-hooks/pre-commit .git/hooks/pre-commit

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'

echo -e "${YELLOW}[Pre-commit] Scan des secrets et credentials...${NC}"

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

SECRETS_PATTERNS=(
    "password\s*=\s*['\"][^'\"]{3,}"
    "secret\s*=\s*['\"][^'\"]{3,}"
    "api_key\s*=\s*['\"][^'\"]{10,}"
    "aws_access_key_id\s*=\s*AK[0-9A-Z]{18}"
    "private_key"
    "BEGIN RSA PRIVATE KEY"
    "BEGIN OPENSSH PRIVATE KEY"
    "token\s*=\s*['\"][a-zA-Z0-9_\-]{20,}"
)

FOUND=0
for FILE in $STAGED_FILES; do
    if [ -f "$FILE" ]; then
        for PATTERN in "${SECRETS_PATTERNS[@]}"; do
            if grep -qiE "$PATTERN" "$FILE" 2>/dev/null; then
                echo -e "${RED}[BLOCKED] Secret potentiel détecté dans: $FILE${NC}"
                echo -e "  Pattern: $PATTERN"
                FOUND=1
            fi
        done
    fi
done

if [ $FOUND -eq 1 ]; then
    echo -e "${RED}╔════════════════════════════════════════════╗${NC}"
    echo -e "${RED}║  COMMIT BLOQUÉ — Secret détecté !          ║${NC}"
    echo -e "${RED}║  Retirez les credentials avant de commiter ║${NC}"
    echo -e "${RED}╚════════════════════════════════════════════╝${NC}"
    exit 1
fi

echo -e "${GREEN}[Pre-commit] Aucun secret détecté. ✔${NC}"
exit 0
