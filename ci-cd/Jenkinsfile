def COLOR_MAP = [
  SUCCESS : 'good',
  UNSTABLE: 'warning',
  FAILURE : 'danger'
]

pipeline {
  agent any

  tools { maven 'M3' }

  environment {
    SONAR_PROJECT_KEY = 'pfe-devsecops-2026'
    DOCKER_IMAGE      = 'pfe-devsecops-2026'
    APP_NAME          = 'devsecops-app'
    N8N_WEBHOOK       = 'http://n8n:5678/webhook/jenkins-event'
    N8N_API_KEY       = 'devsecops-secret-2024'
    PROJECT_ID        = '54192eca-43da-4d8f-9b49-30c143983fdd'
    BACKEND_URL       = 'http://172.31.172.61:3001'
  }

  stages {

    stage('🧹 Clean') {
      steps {
        dir('app') { sh 'mvn clean' }
      }
    }

    stage('⚙️ Compile') {
      steps {
        dir('app') { sh 'mvn compile' }
      }
    }

    stage('🧪 Tests + Coverage') {
      steps {
        dir('app') { sh 'mvn test jacoco:report' }
      }
      post {
        always {
          junit allowEmptyResults: true,
                testResults: 'app/target/surefire-reports/*.xml'
        }
      }
    }

    stage('📦 Package') {
      steps {
        dir('app') {
          sh 'mvn package -DskipTests'
          script {
            def jar = sh(script: "ls target/*.jar | grep -v original | head -1", returnStdout: true).trim()
            env.JAR_NAME = jar.replaceAll('target/', '')
            echo "JAR: ${env.JAR_NAME}"
          }
        }
      }
    }

    stage('🔍 SAST - SonarQube') {
      steps {
        dir('app') {
          withSonarQubeEnv('sq1') {
            sh '''
              /var/jenkins_home/tools/hudson.tasks.Maven_MavenInstallation/M3/bin/mvn \
              org.sonarsource.scanner.maven:sonar-maven-plugin:4.0.0.4121:sonar \
              -Dsonar.projectKey=$SONAR_PROJECT_KEY
            '''
          }
        }
      }
    }

    stage('🛡️ SCA - OWASP') {
      steps {
        dir('app') {
          sh '''
            mvn org.owasp:dependency-check-maven:check \
              -DfailBuildOnCVSS=7 \
              -DnvdApiKey=14EB33B7-AB3A-F111-836A-129478FCB64D \
              -Dformats=HTML,JSON || true
          '''
        }
      }
      post {
        always {
          publishHTML(target: [
            reportDir: 'app/target', reportFiles: 'dependency-check-report.html',
            reportName: 'OWASP Dependency Check'
          ])
        }
      }
    }

    stage('📤 Deploy Nexus') {
      steps {
        dir('app') {
          sh 'mvn deploy -DskipTests -Ddependency-check.skip=true --settings /var/jenkins_home/.m2/settings.xml'
        }
      }
    }

    stage('🐳 Build Docker') {
      steps {
        dir('app') {
          sh "docker build --build-arg JAR_FILE=${env.JAR_NAME} -t ${DOCKER_IMAGE}:latest ."
        }
      }
    }

    stage('🔒 Container Scan - Trivy') {
      steps {
        sh "trivy image --exit-code 1 --severity CRITICAL --format json --output trivy-report.json ${DOCKER_IMAGE}:latest || true"
      }
      post {
        always {
          archiveArtifacts artifacts: 'trivy-report.json', allowEmptyArchive: true
        }
      }
    }

    stage('📤 Push Docker Hub') {
      steps {
        withCredentials([usernamePassword(
          credentialsId: 'dockerHub',
          usernameVariable: 'DOCKER_HUB_USER',
          passwordVariable: 'DOCKER_HUB_PASS'
        )]) {
          sh """
            echo "${DOCKER_HUB_PASS}" | docker login -u "${DOCKER_HUB_USER}" --password-stdin
            docker tag ${DOCKER_IMAGE}:latest ${DOCKER_HUB_USER}/${DOCKER_IMAGE}:latest
            docker push ${DOCKER_HUB_USER}/${DOCKER_IMAGE}:latest
          """
        }
      }
    }

    stage('🚀 Deploy App') {
      steps {
        sh """
          docker stop ${APP_NAME} 2>/dev/null || true
          docker rm   ${APP_NAME} 2>/dev/null || true
          docker run -d \
            --name ${APP_NAME} \
            --network pfe-network \
            -p 8080:8080 \
            -e DB_HOST=pfe-postgres \
            -e DB_PORT=5432 \
            -e DB_NAME=devsecops \
            -e DB_USER=devsecops \
            -e DB_PASSWORD=devsecops123 \
            ${DOCKER_IMAGE}:latest
        """
      }
    }

    stage('🌐 DAST - OWASP ZAP') {
      steps {
        sh """
          docker run --rm \
            --network pfe-network \
            -v \$(pwd)/security/zap:/zap/wrk \
            ghcr.io/zaproxy/zaproxy:stable \
            zap-baseline.py -t http://${APP_NAME}:8080 -r zap-report.html -I || true
        """
      }
      post {
        always {
          publishHTML(target: [
            reportDir: 'security/zap', reportFiles: 'zap-report.html',
            reportName: 'OWASP ZAP DAST'
          ])
        }
      }
    }
  }

  // ── Post — Notification minimale vers n8n ─────────────────
  // Toute l'intelligence est dans n8n :
  // - Fetch du log complet via Jenkins API
  // - Fetch des métriques SonarQube via API
  // - Extraction automatique des erreurs
  // - Analyse par agents IA
  post {
    always {
      script {
        def buildStatus = currentBuild.currentResult
        def event       = buildStatus == 'SUCCESS' ? 'pipeline_success' : 'pipeline_failed'
        def severity    = buildStatus == 'FAILURE'  ? 'HIGH'
                        : buildStatus == 'UNSTABLE' ? 'MEDIUM' : 'LOW'

        // ── Notification n8n — payload minimal ────────────────
        // n8n récupère lui-même le log complet et les métriques
        try {
          def payload = """{
            "event"          : "${event}",
            "job"            : "${env.JOB_NAME}",
            "build_number"   : "${env.BUILD_NUMBER}",
            "build_url"      : "${env.BUILD_URL}",
            "logs_url"       : "${env.BUILD_URL}consoleText",
            "branch"         : "${env.GIT_BRANCH ?: 'unknown'}",
            "status"         : "${buildStatus}",
            "severity"       : "${severity}",
            "project_id"     : "${env.PROJECT_ID}",
            "sonar_project_key": "${env.SONAR_PROJECT_KEY}"
          }"""

          httpRequest(
            url                : env.N8N_WEBHOOK,
            httpMode           : 'POST',
            contentType        : 'APPLICATION_JSON',
            requestBody        : payload,
            customHeaders      : [[name: 'X-API-Key', value: env.N8N_API_KEY]],
            ignoreSslErrors    : true,
            validResponseCodes : '100:599'
          )
          echo "n8n notifie: ${event}"
        } catch (Exception e) {
          echo "n8n failed: ${e.message}"
        }

        // ── Email ─────────────────────────────────────────────
        try {
          emailext(
            subject : "Build ${buildStatus}: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
            body    : "<p>Status: ${buildStatus}</p><p><a href='${env.BUILD_URL}'>Voir le build</a></p>",
            to      : 'souhaiel.amri@esprit.tn',
            mimeType: 'text/html'
          )
        } catch (Exception e) {
          echo "Email failed: ${e.message}"
        }

        // ── Slack ─────────────────────────────────────────────
        try {
          slackSend(
            channel : '#souhaiel',
            color   : COLOR_MAP[buildStatus] ?: 'warning',
            message : "*${buildStatus}:* `${env.JOB_NAME}` #${env.BUILD_NUMBER} ${env.BUILD_URL}"
          )
        } catch (Exception e) {
          echo "Slack failed: ${e.message}"
        }

        // ── Backend Dashboard ──────────────────────────────────
        try {
          httpRequest(
            url                : "${env.BACKEND_URL}/api/webhooks/jenkins/${env.PROJECT_ID}",
            httpMode           : 'POST',
            contentType        : 'APPLICATION_JSON',
            requestBody        : """{"name":"${env.JOB_NAME}","build":{"phase":"FINALIZED","status":"${buildStatus}","number":"${env.BUILD_NUMBER}","url":"${env.BUILD_URL}"}}""",
            ignoreSslErrors    : true,
            validResponseCodes : '100:599'
          )
          echo "Backend notifie"
        } catch (Exception e) {
          echo "Backend failed: ${e.message}"
        }
      }
    }
  }
}
