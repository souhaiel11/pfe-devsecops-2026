def COLOR_MAP = [
  SUCCESS : 'good',
  UNSTABLE: 'warning',
  FAILURE : 'danger'
]

pipeline {
  agent any

  tools {
    maven 'M3'
  }

  environment {
    SONAR_PROJECT_KEY = 'pfe-devsecops-2026'
    DOCKER_IMAGE      = 'pfe-devsecops-2026'
    APP_NAME          = 'devsecops-app'
  }

  stages {

    // ── 1. Clean ─────────────────────────────────────────────
    stage('🧹 Clean') {
      steps {
        dir('app') {
          sh 'mvn clean'
        }
      }
    }

    // ── 2. Compile ───────────────────────────────────────────
    stage('⚙️ Compile') {
      steps {
        dir('app') {
          sh 'mvn compile'
        }
      }
    }

    // ── 3. Tests + Coverage JaCoCo ───────────────────────────
    stage('🧪 Tests + Coverage') {
      steps {
        dir('app') {
          sh 'mvn test jacoco:report'
        }
      }
      post {
        always {
          junit allowEmptyResults: true,
                testResults: 'app/target/surefire-reports/*.xml'
        }
      }
    }

    // ── 4. Package ───────────────────────────────────────────
    stage('📦 Package + Detect JAR') {
      steps {
        dir('app') {
          sh 'mvn package -DskipTests'
          script {
            def jar = sh(
              script: "ls target/*.jar | grep -v 'original' | head -n 1",
              returnStdout: true
            ).trim()
            env.JAR_NAME = jar.replaceAll('target/', '')
            echo "JAR détecté : ${env.JAR_NAME}"
          }
        }
      }
    }

    // ── 5. SAST — SonarQube ──────────────────────────────────
    stage('🔍 SAST - SonarQube') {
      steps {
        dir('app') {
          withSonarQubeEnv('sq1') {
            sh '''
              /var/jenkins_home/tools/hudson.tasks.Maven_MavenInstallation/M3/bin/mvn \
              org.sonarsource.scanner.maven:sonar-maven-plugin:4.0.0.4121:sonar \
              -Dsonar.projectKey=$SONAR_PROJECT_KEY
            '''
          }
        }
      }
    }

    // ── 6. SCA — OWASP Dependency Check ─────────────────────
    stage('🛡️ SCA - OWASP Dependency Check') {
      steps {
        dir('app') {
          sh '''
            mvn org.owasp:dependency-check-maven:check \
              -DfailBuildOnCVSS=7 \
              -DnvdApiKey=14EB33B7-AB3A-F111-836A-129478FCB64D \
              -Dformats=HTML,JSON \
              || true
          '''
        }
      }
      post {
        always {
          publishHTML(target: [
            reportDir:   'app/target',
            reportFiles: 'dependency-check-report.html',
            reportName:  'OWASP Dependency Check'
          ])
        }
      }
    }

    // ── 7. Deploy Nexus ──────────────────────────────────────
    stage('📤 Deploy Nexus') {
      steps {
        dir('app') {
          sh 'mvn deploy -DskipTests -Ddependency-check.skip=true --settings /var/jenkins_home/.m2/settings.xml'
        }
      }
    }

    // ── 8. Build Docker ──────────────────────────────────────
    stage('🐳 Build Docker') {
      steps {
        dir('app') {
          sh "docker build --build-arg JAR_FILE=${env.JAR_NAME} -t ${DOCKER_IMAGE}:latest ."
        }
      }
    }

    // ── 9. Container Scan — Trivy ────────────────────────────
    stage('🔒 Container Scan - Trivy') {
      steps {
        script {
          sh """
            trivy image \
              --exit-code 1 \
              --severity CRITICAL \
              --format json \
              --output trivy-report.json \
              ${DOCKER_IMAGE}:latest || true
          """

          def reportJson = readFile('trivy-report.json')
          def report     = new groovy.json.JsonSlurper().parseText(reportJson)

          def criticalCount = 0
          def highCount     = 0

          report.Results?.each { result ->
            result.Vulnerabilities?.each { vuln ->
              if (vuln.Severity == 'CRITICAL') criticalCount++
              if (vuln.Severity == 'HIGH')     highCount++
            }
          }

          echo "🔴 CRITICAL: ${criticalCount} | 🟠 HIGH: ${highCount}"
          env.TRIVY_CRITICAL = "${criticalCount}"
          env.TRIVY_HIGH     = "${highCount}"

          if (criticalCount > 0) {
            error("🚨 Trivy: ${criticalCount} vulnérabilité(s) CRITICAL détectée(s) !")
          }
        }
      }
      post {
        always {
          archiveArtifacts artifacts: 'trivy-report.json',
                           allowEmptyArchive: true
        }
      }
    }

    // ── 10. Push Docker Hub ──────────────────────────────────
    stage('📤 Push Docker Hub') {
      steps {
        withCredentials([usernamePassword(
          credentialsId: 'dockerHub',
          usernameVariable: 'DOCKER_HUB_USER',
          passwordVariable: 'DOCKER_HUB_PASS'
        )]) {
          sh """
            echo "${DOCKER_HUB_PASS}" | docker login -u "${DOCKER_HUB_USER}" --password-stdin
            docker tag ${DOCKER_IMAGE}:latest ${DOCKER_HUB_USER}/${DOCKER_IMAGE}:latest
            docker push ${DOCKER_HUB_USER}/${DOCKER_IMAGE}:latest
          """
        }
      }
    }

    // ── 11. Deploy App ───────────────────────────────────────
    stage('🚀 Deploy App') {
      steps {
        sh """
          docker stop ${APP_NAME} 2>/dev/null || true
          docker rm   ${APP_NAME} 2>/dev/null || true
          docker run -d \
            --name ${APP_NAME} \
            --network pfe-network \
            -p 8080:8080 \
            -e DB_HOST=pfe-postgres \
            -e DB_PORT=5432 \
            -e DB_NAME=devsecops \
            -e DB_USER=devsecops \
            -e DB_PASSWORD=devsecops123 \
            ${DOCKER_IMAGE}:latest
        """
      }
    }

    // ── 12. DAST — OWASP ZAP ────────────────────────────────
    stage('🌐 DAST - OWASP ZAP') {
      steps {
        sh """
          docker run --rm \
            --network pfe-network \
            -v \$(pwd)/security/zap:/zap/wrk \
            ghcr.io/zaproxy/zaproxy:stable \
            zap-baseline.py \
            -t http://${APP_NAME}:8080 \
            -r zap-report.html \
            -I || true
        """
      }
      post {
        always {
          publishHTML(target: [
            reportDir:   'security/zap',
            reportFiles: 'zap-report.html',
            reportName:  'OWASP ZAP DAST'
          ])
        }
      }
    }
  }

  // ── Post — Notifications ──────────────────────────────────
  post {
    always {
      script {
        def buildStatus = currentBuild.currentResult

        // ── Email ────────────────────────────────────────────
        emailext(
          subject: "📬 Build ${buildStatus}: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
          body: """
            <p>📌 Project  : ${env.JOB_NAME}</p>
            <p>🔢 Build    : ${env.BUILD_NUMBER}</p>
            <p>📊 Status   : ${buildStatus}</p>
            <p>🔴 Critical : ${env.TRIVY_CRITICAL ?: 0}</p>
            <p>🟠 High     : ${env.TRIVY_HIGH ?: 0}</p>
            <p>🔗 <a href="${env.BUILD_URL}">${env.BUILD_URL}</a></p>
          """,
          to       : 'souhaiel.amri@esprit.tn',
          from     : 'souhaiel.amri@esprit.tn',
          replyTo  : 'souhaiel.amri@esprit.tn',
          mimeType : 'text/html'
        )

        // ── Slack ────────────────────────────────────────────
        try {
          slackSend(
            channel : '#souhaiel',
            color   : COLOR_MAP[buildStatus] ?: 'warning',
            message : "*${buildStatus}:* Job `${env.JOB_NAME}` build `${env.BUILD_NUMBER}`\nURL: ${env.BUILD_URL}"
          )
        } catch (Exception e) {
          echo "Slack notification failed: ${e.message}"
        }

        // ── n8n — DevSecOps IA Notification ─────────────────
        try {
          def event = (buildStatus == 'SUCCESS')  ? 'pipeline_success'
                    : (buildStatus == 'UNSTABLE') ? 'pipeline_failed'
                    : 'pipeline_failed'

          def severity = (buildStatus == 'FAILURE')  ? 'HIGH'
                       : (buildStatus == 'UNSTABLE') ? 'MEDIUM'
                       : 'LOW'

          def payload = """{
            "event"          : "${event}",
            "job"            : "${env.JOB_NAME}",
            "build_number"   : "${env.BUILD_NUMBER}",
            "build_url"      : "${env.BUILD_URL}",
            "logs_url"       : "${env.BUILD_URL}consoleText",
            "branch"         : "${env.GIT_BRANCH ?: 'unknown'}",
            "severity"       : "${severity}",
            "trivy"          : {
              "critical": ${env.TRIVY_CRITICAL ?: 0},
              "high"    : ${env.TRIVY_HIGH ?: 0}
            },
            "sonarProjectKey": "${env.SONAR_PROJECT_KEY}",
            "build"          : {
              "status": "${buildStatus}",
              "phase" : "FINALIZED"
            }
          }"""

          httpRequest(
            url                : 'http://n8n:5678/webhook/jenkins-event',
            httpMode           : 'POST',
            contentType        : 'APPLICATION_JSON',
            requestBody        : payload,
            customHeaders      : [[name: 'X-API-Key', value: 'devsecops-secret-2024']],
            ignoreSslErrors    : true,
            validResponseCodes : '100:599'
          )
          echo "✅ n8n notifié — event: ${event}"
        } catch (Exception e) {
          echo "⚠️ n8n notification failed: ${e.message}"
        }
      }
    }
  }
}
